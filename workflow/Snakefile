import os
import glob
import pandas as pd
import re

input_dir = config["in_dir"]
output_dir = config["out_dir"]

localrules: quast, mob_init, mobsuite, afp_init, annotate_amr, mlst, seqsero, resfinder, summarize_results

# ----------------------------------------------
#   Build a mapping from sample R1 and R2 files
# ----------------------------------------------

def extract_sample_name(filename):
    base = os.path.basename(filename)
    if base.endswith('.gz'):
        base = base[:-3]
    # Accept _R1_001, _R1, _1, etc.
    m = re.match(r"(.+?)(?:_R?1(?:_001)?|_1)(?:\.fastq)?$", base)
    if m:
        return m.group(1)
    else:
        return re.sub(r"(_R?1(?:_001)?|_1)(\.fastq)?(\.gz)?$", "", base)

# Find all possible R1 and R2 files (gzipped and not)
r1_files = glob.glob(os.path.join(input_dir, "*R1*.fastq*")) + glob.glob(os.path.join(input_dir, "*_1.fastq*"))
r2_files = glob.glob(os.path.join(input_dir, "*R2*.fastq*")) + glob.glob(os.path.join(input_dir, "*_2.fastq*"))

# Build mapping {sample: {r1: path, r2: path}}
sample_to_files = {}
for r1 in r1_files:
    sample = extract_sample_name(r1)
    # Try to find corresponding R2
    possible_r2s = [
        r1.replace('R1', 'R2'),
        r1.replace('_1', '_2')
    ]
    found_r2 = None
    for r2_candidate in possible_r2s:
        if os.path.exists(r2_candidate):
            found_r2 = r2_candidate
            break
    # Fallback: try to match by sample name
    if not found_r2:
        for r2 in r2_files:
            if extract_sample_name(r2) == sample:
                found_r2 = r2
                break
    if found_r2:
        sample_to_files[sample] = {'r1': r1, 'r2': found_r2}

samples = sorted(sample_to_files.keys())

# Define file calling functions
def get_r1(wildcards):
    return sample_to_files[wildcards.sample]['r1']

def get_r2(wildcards):
    return sample_to_files[wildcards.sample]['r2']


# ------------------------------------------
#   Define the target outputs for pipeline
# ------------------------------------------

rule all:
    input:
        expand(os.path.join(output_dir, "assemblies", "chromosomes", "{sample}.chromosome.fasta"), sample=samples),
        expand(os.path.join(output_dir, "data", "amrfinderplus", "chromosomes", "{sample}.afp.tsv"), sample=samples),
        os.path.join(output_dir, "data", "quast", "report.tsv"),
        os.path.join(output_dir, "data", "gtdb-tk", "gtdbtk.bac120.summary.tsv"),
        os.path.join(output_dir, "data", "checkm", "genome.stats.tsv"),
        os.path.join(output_dir, "data", "mlst", "mlst.tsv"),
        lambda wildcards: expand(os.path.join(output_dir, "data", "serotyping", "Salmonella", "{sample}", "SeqSero_result.tsv"), sample=get_serotyping_samples(wildcards)[0]),
        expand(os.path.join(output_dir, "data", "resfinder", "{sample}", "ResFinder_results_tab.txt"), sample=samples),
        os.path.join(output_dir, "results_summary.csv"),
        os.path.join(output_dir, "salmonella_serotype_all.csv"),
        os.path.join(output_dir, "plasmid_data_long.csv")
        #lambda wildcards: expand(os.path.join(output_dir, "data", "serotyping", "Ecoli", "{{sample}}", "output.tsv"), sample=get_serotyping_samples(wildcards)[1])

# ------------------------------------------
#   Clean and Assemble (fastp + Unicycler)
# ------------------------------------------

rule fastp_and_unicycler:
    input:
        r1 = get_r1,
        r2 = get_r2
    output:
        r1_clean = protected(os.path.join(output_dir, "samples", "{sample}", "{sample}_R1.clean.fastq.gz")),
        r2_clean = protected(os.path.join(output_dir, "samples", "{sample}", "{sample}_R2.clean.fastq.gz")),
        unicycler = protected(os.path.join(output_dir, "samples", "{sample}", "unicycler", "assembly.fasta"))
    params:
        html = "/dev/null/",
        json = "/dev/null/"
    resources:
        mem_mb = 20000,
        threads = 16,
        time = "0-10:00:00"
    benchmark:
        os.path.join(output_dir, "data", "benchmarks", "{sample}.fastp_and_unicycler.txt")
    conda: "envs/assemble.yaml"
    shell:
        """
        # run fastp
        mkdir -p $(dirname {output.r1_clean})
        fastp -i {input.r1} -I {input.r2} -o {output.r1_clean} -O {output.r2_clean} --html {params.html} --json {params.json}

        # run unicycler, keep only pertinent files
        mkdir -p $(dirname {output.unicycler})
        unicycler -1 {output.r1_clean} -2 {output.r2_clean} -o $(dirname {output.unicycler}) -t {resources.threads} --keep 0
        """


# ------------------------------------
#    QA complete assemblies (Quast)
# ------------------------------------

rule quast:
    input:
        assemblies = lambda wildcards: expand(os.path.join(output_dir, "samples", "{sample}", "unicycler", "assembly.fasta"), sample=samples)
    output:
        quast = os.path.join(output_dir, "data", "quast", "report.tsv")
    conda: "envs/quast.yaml"
    shell:
        r"""
        # Create temp directory for symlinks
        tmp_quast_dir=$(mktemp -d $(dirname {output.quast})/quast_input.XXXXXXXX)
        for infile in {input.assemblies}; do
            sample=$(basename $(dirname $(dirname $infile)))
            ln -sf $(realpath $infile) $tmp_quast_dir/${{sample}}.fasta
        done

        mkdir -p $(dirname {output.quast})
        quast.py $tmp_quast_dir/*.fasta -o $(dirname {output.quast}) 

        # Clean up temp symlink dir
        rm -rf $tmp_quast_dir
        """


# -----------------------------------
#    Initialize MOB-suite database
# -----------------------------------

rule mob_init:
    output:
        touch(os.path.join(output_dir,".mob_suite_db_initialized"))
    conda:
        "envs/mob_suite.yaml"
    shell:
        """
        mob_init
        touch {output}
        """

# --------------------------------------------------------------------------
#   Separate chromosome from plasmid(s), type plasmids and MGEs (MOB-suite)
# --------------------------------------------------------------------------

rule mobsuite:
    input:
        assembly = os.path.join(output_dir, "samples", "{sample}", "unicycler", "assembly.fasta"),
        db_init = os.path.join(output_dir,".mob_suite_db_initialized")
    output:
        mob = os.path.join(output_dir, "samples", "{sample}", "mob-suite", "chromosome.fasta"),
        chrom = os.path.join(output_dir, "assemblies", "chromosomes", "{sample}.chromosome.fasta"),
        plas = os.path.join(output_dir, "assemblies", "plasmids", ".{sample}.plasmids.done")
    benchmark:
        os.path.join(output_dir, "data", "benchmarks", "{sample}.mobsuite.txt")
    conda: "envs/mob_suite.yaml"
    shell:
        """
        # run mob_recon to reconstruct and type plasmids leveraging unicycler circularity flags 
        mob_recon --infile {input.assembly} --outdir $(dirname {output.mob}) --unicycler_contigs --force -n {resources.threads}

        # copy chromosome assembly to new directory
        mkdir -p $(dirname {output.chrom})
        cp {output.mob} {output.chrom}

        # copy plasmid(s) to new directory
        for f in $(dirname {output.mob})/plasmid*; do
            if [ -f $f ]; then
                base=$(basename $f)
                cp $f $(dirname {output.plas})/{wildcards.sample}.$base
            fi
        done

        # create marker file to satisfy output
        touch {output.plas}
        """

