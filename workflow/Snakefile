# ----------------------------------------------------
#   Get Salmonella and E. coli samples for serotyping
# ----------------------------------------------------

_serotyping_samples = None

def get_serotyping_samples(wildcards):
    global _serotyping_samples
    if _serotyping_samples is None:
        gtdbtk_output = checkpoints.gtdbtk.get(**wildcards).output[0]
        df = pd.read_csv(gtdbtk_output, sep='\t')
        salmonella_samples = []
        ecoli_samples = []
        entero_samples = []
        for _, row in df.iterrows():
            sample = row['user_genome'].replace('.chromosome', '')
            classification = str(row['classification'])
            if "Salmonella" in classification:
                salmonella_samples.append(sample)
            elif "Escherichia" in classification:
                ecoli_samples.append(sample)
            elif "Enterococcus" in classification:
                entero_samples.append(sample)
        print("Salmonella samples:", salmonella_samples)
        print("Ecoli samples:", ecoli_samples)
        print("Enterococcus samples:", entero_samples)
        _serotyping_samples = (salmonella_samples, ecoli_samples, entero_samples)
    return _serotyping_samples


