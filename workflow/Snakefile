# ------------------------------------------------------
#   Get species names from GTDB for input into Resfinder 
# ------------------------------------------------------

RESFINDER_SPECIES = [
    "Campylobacter", "Campylobacter jejuni", "Campylobacter coli", 
    "Enterococcus faecalis", "Enterococcus faecium", "Escherichia coli",
    "Helicobacter pylori", "Klebsiella", "Mycobacterium tuberculosis",
    "Neisseria gonorrhoeae", "Plasmodium falciparum", "Salmonella", 
    "Salmonella enterica", "Staphylococcus aureus"
]

def get_species_name(wildcards):
    gtdbtk_output = checkpoints.gtdbtk.get(**wildcards).output[0]
    df = pd.read_csv(gtdbtk_output, sep='\t')
    sample_fasta = f"{wildcards.sample}.chromosome"
    row = df[df['user_genome'] == sample_fasta]
    if row.empty:
        return "Other"
    classification = str(row.iloc[0]['classification'])
    # Try to get species
    species = None
    genus = None
    for part in classification.split(';'):
        if part.startswith("s__"):
            # Remove prefix, leave spaces intact (no underscores)
            species = part[3:].strip()
        if part.startswith("g__"):
            genus = part[3:].strip()
    # Try full species match
    if species and species in RESFINDER_SPECIES:
        return species
    # Try genus-level match
    if genus:
        # Prefer genus-only models if present
        for s in RESFINDER_SPECIES:
            if s == genus:
                return s
        # Some Resfinder models are "Genus species" (e.g. "Salmonella enterica")
        if species:
            for s in RESFINDER_SPECIES:
                if s.lower() == f"{genus.lower()} {species.lower()}":
                    return s
    # Try partial match (e.g., species contains a model name)
    if species:
        for s in RESFINDER_SPECIES:
            if s.lower() in species.lower():
                return s
    # Fallback: "Other"
    return "Other"



# ------------------------------------------------------
#     Predict phenotype from genotype (Resfinder) 
# ------------------------------------------------------

rule resfinder:
    input:
        assembly=lambda wildcards: os.path.join(output_dir, "samples", wildcards.sample, "unicycler", "assembly.fasta"),
        gtdbtk=lambda wildcards: checkpoints.gtdbtk.get(**wildcards).output[0]
    output:
        results_dir = os.path.join(output_dir, "data", "resfinder", "{sample}", "ResFinder_results_tab.txt")
    params:
        species = lambda wildcards: get_species_name(wildcards),
        res_db = config["res_db"],
        pt_db = config["pt_db"],
        dis_db = config["dis_db"]
    conda:
        "envs/resfinder.yaml"
    benchmark:
        os.path.join(output_dir, "data", "benchmarks", "{sample}.resfinder.txt")
    shell:
        """
        python -m resfinder -ifa {input.assembly} -o $(dirname {output.results_dir}) -s "{params.species}" -t 0.9 -l 0.6 --acquired --point --disinfectant -db_res {params.res_db} -db_point {params.pt_db} -db_disinf {params.dis_db}
        """


# ---------------------------
#    Generate Summary File
# ---------------------------

rule summarize_results:
    input:
        checkm = os.path.join(output_dir, "data", "checkm", "genome.stats.tsv"),
        gtdbtk = os.path.join(output_dir, "data", "gtdb-tk", "gtdbtk.bac120.summary.tsv"),
        mlst   = os.path.join(output_dir, "data", "mlst", "mlst.tsv"),
        quast  = os.path.join(output_dir, "data", "quast", "report.tsv"),
        resfinder_files = expand(os.path.join(output_dir, "data", "resfinder", "{sample}", "ResFinder_results_tab.txt"), sample=samples),
        amr_cr_files = expand(os.path.join(output_dir, "data", "amrfinderplus", "chromosomes", "{sample}.afp.tsv"), sample=samples),
        amr_plas_done = expand(os.path.join(output_dir, "data", "amrfinderplus", "plasmids", ".{sample}.plasmids.afp.done"), sample=samples),
        seqsero_files = lambda wildcards: expand(os.path.join(output_dir, "data", "serotyping", "Salmonella", "{sample}", "SeqSero_result.tsv"), sample=get_serotyping_samples(wildcards)[0]),
        sample_dirs = expand(os.path.join(output_dir, "samples", "{sample}"), sample=samples)
    output:
        summary = os.path.join(output_dir, "results_summary.csv"),
        seqs2 = os.path.join(output_dir, "salmonella_serotype_all.csv"),
        plasmid_summary = os.path.join(output_dir, "plasmid_data_long.csv")
    conda:
        "envs/Renv.yaml"
    script:
        "scripts/data_summary.R"
